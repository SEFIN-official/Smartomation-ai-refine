DEMO2_SMTP_PASSWORD=app-password-2
DEMO2_SMTP_FROM=demo2@example.com
DEMO2_SMTP_USE_TLS=true
DEMO2_EMAIL_SUBJECT=Demo 2 result
# Demo 2 runner credentials:
# DEMO2_LLM_PROVIDER=groq
# DEMO2_GROQ_API_KEY=...
# DEMO2_OPENAI_API_KEY=...

